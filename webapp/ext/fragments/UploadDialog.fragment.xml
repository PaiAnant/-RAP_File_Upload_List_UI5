<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified"
>
    <Dialog
        id="uploadDlg"
        title="Upload Excel"
        contentWidth="30rem"
    >
        <VBox id="_IDGenVBox1" class="sapUiSmallMargin">
            <unified:FileUploader
                id="fuExcel"
                fileType="xlsx,xls"
                placeholder="Choose an Excel file..."
                change=".onFileChange"
                width="100%"
            />
            <Text
                id="txtFile"
                text="No file selected"
                class="sapUiTinyMarginTop"
            />
        </VBox>
        <beginButton>
            <Button id="_IDGenButton"
                text="Upload"
                type="Emphasized"
                press=".onUploadConfirm"
            />
        </beginButton>
        <endButton>
            <Button id="_IDGenButton1"
                text="Cancel"
                press=".onUploadCancel"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
